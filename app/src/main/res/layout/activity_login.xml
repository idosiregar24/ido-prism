<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".TugasPertemuan3.LoginActivity">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/ivBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_proyek" />

    <!-- Dark Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#AA000000" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="32dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1A1C1E"
                app:cardCornerRadius="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <!-- Logo & Branding -->
                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@drawable/logo_bina_desa" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Desa Balam\nSempurna"
                        android:textColor="@color/white"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Login Akun"
                        android:textColor="@color/white"
                        android:textSize="22sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Masuk untuk memantau proyek desa"
                        android:textColor="#BDC3C7"
                        android:textSize="12sp" />

                    <!-- Inputs -->
                    <EditText
                        android:id="@+id/etUsername"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="24dp"
                        android:background="@android:color/white"
                        android:hint="Masukkan Email"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"
                        android:inputType="textEmailAddress" />

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="16dp"
                        android:background="@android:color/white"
                        android:hint="Masukkan password"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular" />

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="@color/red"
                        android:text="Masuk"
                        android:textAllCaps="false"
                        android:fontFamily="@font/poppins_bold"
                        app:cornerRadius="12dp" />

                    <!-- Login Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegisterGmail"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="32dp"
                        android:backgroundTint="@color/red"
                        android:text="Masuk dengan Gmail"
                        android:textAllCaps="false"
                        android:fontFamily="@font/poppins_bold"
                        app:cornerRadius="12dp" />

                    <!-- Footer Link (Minimalist) -->
                    <TextView
                        android:id="@+id/tvRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Belum punya akun? Daftar Sekarang"
                        android:textColor="@color/white"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>