<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".TugasPertemuan4.DashboardGuruActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:background="@color/blue_primary"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@android:color/white"
            app:layout_scrollFlags="scroll|enterAlways"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:layout_marginTop="24dp">

            <TextView
                android:id="@+id/tvImportedTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Memuat Judul..."
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvImportedDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Memuat deskripsi..."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/tvImportedTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/colorInputBg"
                app:cardBackgroundColor="@color/colorCard"
                app:layout_constraintTop_toBottomOf="@id/tvImportedDesc"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/yellowPrimary"
                    android:padding="16dp">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/cvProfilePhoto"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ilustrasi_anak"
                            android:contentDescription="Foto Profil Guru"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvGuruName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Hai Bu, Siti Nurbaya"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        app:layout_constraintVertical_chainStyle="packed"
                        app:layout_constraintTop_toTopOf="@id/cvProfilePhoto"
                        app:layout_constraintBottom_toTopOf="@id/tvGuruEmail"
                        app:layout_constraintStart_toEndOf="@id/cvProfilePhoto"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <TextView
                        android:id="@+id/tvGuruEmail"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="2dp"
                        android:text="siti@gmail.com"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        app:layout_constraintTop_toBottomOf="@id/tvGuruName"
                        app:layout_constraintBottom_toBottomOf="@id/cvProfilePhoto"
                        app:layout_constraintStart_toEndOf="@id/cvProfilePhoto"
                        app:layout_constraintEnd_toEndOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Row 1 Menu -->
            <LinearLayout
                android:id="@+id/menuTambahData"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toBottomOf="@id/cardProfile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/menuCatat">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/greenPrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_agenda"
                        android:contentDescription="Tambah Data"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah Data\nAnak &amp; Orang\nTua"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuCatat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuTambahData"
                app:layout_constraintStart_toEndOf="@id/menuTambahData"
                app:layout_constraintEnd_toStartOf="@id/menuProgress">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/red"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_add"
                        android:contentDescription="Catat Perkembangan"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catat\nPerkembangan\nAnak"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuProgress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuTambahData"
                app:layout_constraintStart_toEndOf="@id/menuCatat"
                app:layout_constraintEnd_toStartOf="@id/menuAssessment">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/yellowPrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:contentDescription="Progress Anak"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress\nAnak"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuAssessment"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuTambahData"
                app:layout_constraintStart_toEndOf="@id/menuProgress"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/bluePrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_search"
                        android:contentDescription="Assessment Terpadu"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Assessment\nTerpadu"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- Row 2 Menu -->
            <LinearLayout
                android:id="@+id/menuPembelajaran"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toBottomOf="@id/menuTambahData"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/menuAktivitas">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/greenPrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:contentDescription="Pembelajaran Digital"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pembelajaran\nDigital"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuAktivitas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuPembelajaran"
                app:layout_constraintStart_toEndOf="@id/menuPembelajaran"
                app:layout_constraintEnd_toStartOf="@id/menuPesan">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/red"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_today"
                        android:contentDescription="Aktivitas dan Kehadiran"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aktivitas dan\nkehadiran"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuPesan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuPembelajaran"
                app:layout_constraintStart_toEndOf="@id/menuAktivitas"
                app:layout_constraintEnd_toStartOf="@id/menuInput">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/yellowPrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_menu_send"
                        android:contentDescription="Pesan Orang Tua"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pesan Orang\nTua"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/menuInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintTop_toTopOf="@id/menuPembelajaran"
                app:layout_constraintStart_toEndOf="@id/menuPesan"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.cardview.widget.CardView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/bluePrimary"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        app:tint="@color/white"
                        android:src="@android:drawable/ic_input_add"
                        android:contentDescription="Input Data Anak"/>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Input Data\nAnak"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:textAlignment="center"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>